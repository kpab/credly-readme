{
  "name": "credly-readme",
  "version": "0.1.0",
  "description": "Import your Credly badges into your GitHub profile README.",
  "main": "dist/index.js",
  "scripts": {
    "lint": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "build": "ncc build src/index.ts -o dist",
    "ci": "npm run lint && npm run test && npm run build"
  },
