    "badges"
  ],
  "author": "kpab",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
